@page
@model IndexModel

<!DOCTYPE html>
<html>
<head>
    <title>Twisted Layered Reservoir</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body>

<h2>Twisted Layered Reservoir Calculator</h2>

<form method="post">
    <label>Height:</label>
    <input asp-for="Height" /><br>

    <label>Radius:</label>
    <input asp-for="Radius" /><br>

    <label>Twist (degrees):</label>
    <input asp-for="Twist" /><br>

    <label>Layers:</label>
    <input asp-for="Layers" /><br>

    <button type="submit">Calculate</button>
</form>

@if (Model.Volume > 0)
{
    <h3>Volume: @Model.Volume.ToString("F2")</h3>
}

<div id="canvas3d" style="width:600px;height:400px;"></div>

<script>
function draw3D() {
    const height = @Model.Height;
    const radius = @Model.Radius;
    const twist = @Model.Twist;
    const layers = @Model.Layers;

    if (layers <= 0) return;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, 600/400, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer();

    renderer.setSize(600, 400);
    document.getElementById("canvas3d").innerHTML = "";
    document.getElementById("canvas3d").appendChild(renderer.domElement);

    const material = new THREE.PointsMaterial({ size: 0.1 });
    const geometry = new THREE.BufferGeometry();

    let vertices = [];
    let step = height / layers;

    for (let i = 0; i < layers; i++) {
        let angle = (twist * i) * Math.PI / 180;
        let r = radius * (1 - i / layers);

        for (let t = 0; t < Math.PI * 2; t += 0.2) {
            let x = r * Math.cos(t + angle);
            let y = i * step;
            let z = r * Math.sin(t + angle);
            vertices.push(x, y, z);
        }
    }

    geometry.setAttribute('position', new THREE.Float32BufferAttribute(vertices, 3));
    const points = new THREE.Points(geometry, material);

    scene.add(points);
    camera.position.z = 10;

    function animate() {
        requestAnimationFrame(animate);
        points.rotation.y += 0.01;
        renderer.render(scene, camera);
    }

    animate();
}

@if (Model.Layers > 0)
{
    <text>draw3D();</text>
}
</script>

</body>
</html>